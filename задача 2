#include <iostream>
using namespace std;

int main() {
    double a, b;
    char op;

    cout << "Введите первое число: ";
    cin >> a;
    cout << "Введите операцию (+, -, *, /): ";
    cin >> op;
    cout << "Введите второе число: ";
    cin >> b;

    switch (op) {
        case '+':
            cout << a << " + " << b << " = " << a + b << endl;
            break;
        case '-':
            cout << a << " - " << b << " = " << a - b << endl;
            break;
        case '*':
            cout << a << " * " << b << " = " << a * b << endl;
            break;
        case '/':
            if (b != 0)
                cout << a << " / " << b << " = " << a / b << endl;
            else
                cout << "Ошибка: деление на ноль!" << endl;
            break;
        default:
            cout << "Ошибка: неверная операция!" << endl;
    }

    return 0;
}
