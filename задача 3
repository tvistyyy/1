#include <iostream>
#include <iomanip>
int main() {
    std::cout << "цикл for";
    for (int i = 25; i <= 35; ++i) {
        std::cout << std::fixed << std::setprecision(1)
                  << i << "   "
                  << i + 0.5 << "   "
                  << i - 0.2 << "\n";
    }
    return 0;
    }
      
#include <iostream>
#include <iomanip>
int main() 
    {
    std::cout << "цикл while";
    int i = 25;
    while (i <= 35) {
        std::cout << std::fixed << std::setprecision(1)
                  << i << "   "
                  << i + 0.5 << "   "
                  << i - 0.2 << "\n";
        ++i;
    }
    return 0;
    } 

#include <iostream>
#include <iomanip>
int main() {
    std::cout << "цикл do while";
    int i = 25;
    do {
        std::cout << std::fixed << std::setprecision(1)
                  << i << "   "
                  << i + 0.5 << "   "
                  << i - 0.2 << "\n";
        ++i;
    } while (i <= 35);
    return 0;
    }
